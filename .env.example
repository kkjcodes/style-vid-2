# Copy to .env and fill in real values. Never commit .env to git.

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development           # set to "production" when deploying

# ── Security ──────────────────────────────────────────────────────────────────
# Generate ENCRYPTION_KEY:  python -c "import secrets,base64; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
# Generate JWT_SECRET:       python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=REPLACE_WITH_STRONG_RANDOM_BASE64_KEY
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_HEX
JWT_EXPIRY_HOURS=720         # 30 days; reduce to 24 when you add refresh tokens

# ── Storage ───────────────────────────────────────────────────────────────────
LOCAL_STORAGE_DIR=/tmp/stylevid2
SQLITE_DB_URL=sqlite:////tmp/stylevid2/app.db   # mount a persistent volume in prod
# Preferred in production (Azure PostgreSQL):
# DATABASE_URL=postgresql+psycopg2://<user>:<pass>@<host>:5432/<db>?sslmode=require
DATABASE_URL=

# ── Queue ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── App URL (used in password-reset emails) ───────────────────────────────────
APP_URL=http://localhost:8000          # change to your public URL in production

# ── CORS (Cross-Origin Resource Sharing) ──────────────────────────────────────
# Restrict allowed origins to prevent cross-site request attacks.
# Comma-separated list: http://localhost:3000,https://yourdomain.com
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ── SMTP (password reset emails) ─────────────────────────────────────────────
# Leave SMTP_HOST empty to disable email — reset links will be logged locally.
# Gmail: enable 2FA then create an App Password at myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=you@gmail.com

# ── Azure (production) ────────────────────────────────────────────────────────
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;...
# AZURE_STORAGE_CONTAINER=stylevid
# Optional if you mount Azure File Share to /tmp/stylevid2:
# AZURE_FILE_SHARE=stylevid-files
